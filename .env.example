# Copy this file to ".env" (or set these in your shell / host) to configure Tribes.

# Neon / Postgres connection string. When set, saved games persist to the database.
# Get this from your Neon project dashboard → Connection Details → "Connection string".
# Leave it unset to fall back to local JSON files under ./saves.
#
# Example:
# DATABASE_URL=postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/tribes?sslmode=require
DATABASE_URL=

# Port the web server listens on (default 3000).
# PORT=3000
